POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── Vercel KV (Redis) ─────────────────────────────────────────────────────────
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=
