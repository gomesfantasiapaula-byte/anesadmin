GOOGLE_CLIENT_SECRET=

# ── Vercel Postgres ───────────────────────────────────────────────────────────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
